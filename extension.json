{
	"name": "VEExtend",
	"author": [
		"Mark A. Hershberger <mah@everybody.org>"
	],
	"url": "https://www.mediawiki.org/wiki/Extension:VEExtend",
	"descriptionmsg": "veextend-desc",
	"license-name": "GPL-3.0-or-later",
	"type": "other",
	"requires": {
		"MediaWiki": ">= 1.41.0",
		"extensions": {
			"VisualEditor": "*"
		}
	},
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\VEExtend\\": "src/"
	},
	"HookHandlers": {
		"VEExtendHooks": {
			"class": "MediaWiki\\Extension\\VEExtend\\Hooks"
		}
	},
	"Hooks": {
		"VisualEditorBeforeEditor": "VEExtendHooks"
	},
	"MessagesDirs": {
		"VEExtend": [
			"i18n"
		]
	},
	"ResourceFileModulePaths": {
		"localBasePath": "resources",
		"remoteExtPath": "VEExtend/resources"
	},
	"ResourceModules": {
		"ext.VEExtend": {
			"scripts": [
				"ui/ve.ui.CommandRegistry.js",
				"ui/tools/ve.ui.CenterParagraphFormatTool.js",
				"dm/nodes/ve.dm.CenterParagraphNode.js",
				"ce/nodes/ve.ce.CenterParagraphNode.js",
				"ui/tools/ve.ui.AnnotationsTool.js",
				"dm/annotations/ve.dm.InverseAnnotation.js",
				"ce/annotations/ve.ce.InverseAnnotation.js"
			],
			"styles": [
				"ce/styles/nodes/ve.ce.CenterParagraphNode.css",
				"ce/styles/annotations/ve.ce.InverseAnnotation.css"
			],
			"dependencies": [
				"ext.visualEditor.core",
				"ext.visualEditor.mwwikitext"
			],
			"messages": [
				"veextend-centerparagraph-tooltip",
				"veextend-annotationbutton-inverse-tooltip"
			]
		}
	},
	"manifest_version": 2
}
